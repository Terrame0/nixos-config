[window]
# No external border around the Wofi window
border = "none"         # removes default Wofi/GTK border
margin = 0              # optional: remove margin around window
padding = 20            # keep some padding inside window

# Optional: control size
width = 400             # fixed width
lines = 3
no_actions=true


[appearance]
# Use your theme colors via CSS instead of Wofi defaults
prompt = launch
hide_scroll = true
[behavior]
content_halign=fill
single_click=true

matching=fuzzy
location=center


